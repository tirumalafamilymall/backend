generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String    @id @default(uuid())
  firebase_uid String    @unique
  email        String?
  name         String?
  created_at   DateTime  @default(now())
  role         Role      @default(USER)
  cart         Cart?
  orders       Order[]
  wishlist     Wishlist?
}

// ─── ENUMS ──────────────────────────────────────────────────

enum Department {
  WOMEN
  MEN
  KIDS
}

enum SalesChannel {
  MAIN_STORE
  INSTA_LIVE
}

// ─── THE PARENT BLUEPRINT ───────────────────────────────────

model Product {
  id                  String             @id @default(uuid())
  product_code        String             @unique
  name                String
  department          Department
  category            String
  subcategory         String?
  brand               String?
  images              String[]
  is_active           Boolean            @default(true)
  is_deleted          Boolean            @default(false)
  sales_channel       SalesChannel       @default(MAIN_STORE)
  slug                String             @unique // MADE REQUIRED
  created_at          DateTime           @default(now())
  updated_at          DateTime           @updatedAt
  
  variants            ProductVariant[]
  insta_live_products InstaLiveProduct[]
  wishlist_items      WishlistItem[]
  order_items         OrderItem[]        

  // INDEXES FOR FAST FILTERING
  @@index([department])
  @@index([category])
  @@index([subcategory])
  @@index([brand])
  @@index([sales_channel])
  @@index([is_active])
  @@index([is_deleted])
  @@index([name])
}

// ─── THE CHILD PHYSICAL ITEM ────────────────────────────────

model ProductVariant {
  id          String      @id @default(uuid())
  product_id  String
  sku         String      @unique // ADDED FOR INVENTORY/BARCODES
  size        String?
  color       String?
  base_price  Decimal     @db.Decimal(10,2) // DECIMAL FOR EXACT CURRENCY
  stock       Int         @default(0)
  barcode     String?
  created_at  DateTime    @default(now())
  updated_at  DateTime    @updatedAt

  product     Product     @relation(fields: [product_id], references: [id], onDelete: Cascade)
  cart_items  CartItem[]
  order_items OrderItem[]

  @@index([product_id])
  @@index([stock])
  @@unique([product_id, size, color])
}

// ─── CART & ORDERS ──────────────────────────────────────────

model Cart {
  id         String     @id @default(uuid())
  user_id    String     @unique
  created_at DateTime   @default(now())
  updated_at DateTime   @updatedAt
  user       User       @relation(fields: [user_id], references: [id])
  items      CartItem[]
}

model CartItem {
  id         String         @id @default(uuid())
  cart_id    String
  variant_id String         
  quantity   Int            @default(1)
  created_at DateTime       @default(now())
  updated_at DateTime       @updatedAt
  
  cart       Cart           @relation(fields: [cart_id], references: [id], onDelete: Cascade) // CASCADE DELETE ADDED
  variant    ProductVariant @relation(fields: [variant_id], references: [id], onDelete: Cascade)

  @@unique([cart_id, variant_id])
}

model Order {
  id                  String        @id @default(uuid())
  order_number        String        @unique
  user_id             String
  status              OrderStatus   @default(PENDING)
  total_amount        Decimal       @db.Decimal(10,2) // DECIMAL
  shipping_amount     Decimal       @db.Decimal(10,2) @default(0) // DECIMAL
  payment_status      PaymentStatus @default(UNPAID)
  payment_id          String?
  razorpay_order_id   String?
  shipping_address    Json
  shiprocket_order_id String?
  tracking_url        String?
  notes               String?
  created_at          DateTime      @default(now())
  updated_at          DateTime      @updatedAt
  
  user                User          @relation(fields: [user_id], references: [id])
  items               OrderItem[]

  @@index([user_id])
  @@index([status])
  @@index([payment_status])
  @@index([created_at])
}

model OrderItem {
  id           String          @id @default(uuid())
  order_id     String
  product_id   String          
  variant_id   String?         
  product_code String
  name         String
  category     String
  brand        String?
  color        String?
  size         String?
  price        Decimal         @db.Decimal(10,2) // DECIMAL
  quantity     Int
  image        String?
  created_at   DateTime        @default(now())
  
  order        Order           @relation(fields: [order_id], references: [id])
  product      Product         @relation(fields: [product_id], references: [id])
  variant      ProductVariant? @relation(fields: [variant_id], references: [id])
}

// ─── INSTA LIVE & WISHLIST ──────────────────────────────────

model InstaLive {
  id            String             @id @default(uuid())
  title         String?
  instagram_url String
  thumbnail     String
  is_active     Boolean            @default(true)
  created_at    DateTime           @default(now())
  updated_at    DateTime           @updatedAt
  products      InstaLiveProduct[]
}

model InstaLiveProduct {
  id            String    @id @default(uuid())
  insta_live_id String
  product_id    String    
  
  insta_live    InstaLive @relation(fields: [insta_live_id], references: [id], onDelete: Cascade)
  product       Product   @relation(fields: [product_id], references: [id], onDelete: Cascade)

  @@unique([insta_live_id, product_id])
}

model Wishlist {
  id         String         @id @default(uuid())
  user_id    String         @unique
  created_at DateTime       @default(now())
  updated_at DateTime       @updatedAt
  user       User           @relation(fields: [user_id], references: [id])
  items      WishlistItem[]
}

model WishlistItem {
  id          String   @id @default(uuid())
  wishlist_id String
  product_id  String   
  created_at  DateTime @default(now())
  
  product     Product  @relation(fields: [product_id], references: [id], onDelete: Cascade)
  wishlist    Wishlist @relation(fields: [wishlist_id], references: [id], onDelete: Cascade)

  @@unique([wishlist_id, product_id])
}

// ─── STATUS ENUMS ───────────────────────────────────────────

enum OrderStatus {
  PENDING
  CONFIRMED
  SHIPPED
  DELIVERED
  CANCELLED
}

enum PaymentStatus {
  UNPAID
  PAID
  REFUNDED
}

enum Role {
  USER
  ADMIN
}